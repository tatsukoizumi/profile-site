---
import Layout from "../layouts/Layout.astro";

interface Skill {
  name: string;
  primary?: boolean;
}

interface SkillCategory {
  category: string;
  items: Skill[];
}

const skills: SkillCategory[] = [
  {
    category: "Languages",
    items: [
      { name: "TypeScript", primary: true },
      { name: "JavaScript", primary: true },
      { name: "HTML", primary: true },
      { name: "CSS", primary: true },
      { name: "Go", primary: true },
      { name: "Python" },
      { name: "Ruby" },
    ],
  },
  {
    category: "Frameworks / Libraries",
    items: [
      { name: "React", primary: true },
      { name: "Next.js", primary: true },
      { name: "Astro", primary: true },
      { name: "Echo" },
      { name: "gqlgen" },
      { name: "Ruby on Rails" },
    ],
  },
  {
    category: "Infra / DB",
    items: [
      { name: "PostgreSQL" },
      { name: "MySQL" },
      { name: "AWS" },
      { name: "Cloudflare" },
      { name: "Docker" },
    ],
  },
  {
    category: "Tools",
    items: [
      { name: "Git / GitHub" },
      { name: "GitHub Actions" },
      { name: "Figma" },
      { name: "Cursor" },
      { name: "Claude Code" },
      { name: "Playwright" },
    ],
  },
];
---

<Layout prefix="Skills">
  <h1 class="page-title">Skills</h1>
  <div class="card primary">得意👍</div>

  <div class="skills">
    {
      skills.map((s) => (
        <section class="skill-card">
          <h2>{s.category}</h2>
          <ul>
            {s.items.map((i) => (
              <li class:list={[{ primary: i.primary }]}>{i.name}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</Layout>

<style>
  .page-title {
    font-size: 1.5rem;
    margin: 0 0 0.4rem;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    width: fit-content;
    padding: 0.3rem 0.8rem;
    margin: 0 0 1.2rem;
  }

  .primary {
    border-color: var(--accent);
    color: var(--accent);
    font-weight: 500;
  }

  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .skill-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.1rem;
  }

  .skill-card h2 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 0.7rem;
  }

  .skill-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-card li {
    font-size: 0.9rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.15rem 0.55rem;
  }
</style>
