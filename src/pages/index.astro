---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import SocialIcon from "../components/SocialIcon.astro";
import icon from "../assets/icon.png";

const links = [
  { label: "GitHub", href: "https://github.com/tatsukoizumi" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/tatsukoizumi" },
  { label: "Zenn", href: "https://zenn.dev/tatsukoizumi" },
];
---

<Layout>
  <section class="hero">
    <Image
      class="avatar"
      src={icon}
      alt="アイコン画像"
      width={176}
      height={176}
      format="webp"
      quality={80}
      loading="eager"
      decoding="sync"
      fetchpriority="high"
    />
    <div class="hero-text">
      <div class="name">
        <h1>小泉 辰徳</h1>
        <p class="supporting-text">Koizumi Tatsunori</p>
      </div>
      <p class="supporting-text meta">
        <span>Software Engineer (Freelance)</span>
        <span class="location">
          <svg
            width="14px"
            height="14px"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 21C15.5 17.4 19 14.1764 19 10.2C19 6.22355 15.866 3 12 3C8.13401 3 5 6.22355 5 10.2C5 14.1764 8.5 17.4 12 21Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M12 12C13.1046 12 14 11.1046 14 10C14 8.89543 13.1046 8 12 8C10.8954 8 10 8.89543 10 10C10 11.1046 10.8954 12 12 12Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span>山梨⇆東京</span>
        </span>
      </p>
    </div>
  </section>
  <p class="bio">
    フリーランスのソフトウェアエンジニア。
    <br />
    Webアプリの開発全般に対応可能で、フロントエンドや UI/UX の作り込みを得意としています。
    <br />
    東京と山梨の自宅を行き来する生活を送っています。
  </p>

  <ul class="links">
    {
      links.map((l) => (
        <li>
          <a href={l.href} target="_blank" rel="noopener noreferrer">
            <SocialIcon name={l.label} />
            <span>{l.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 0.5rem 0 1.4rem;
  }

  .avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
    background: var(--card);
    flex-shrink: 0;
  }

  .name {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.1rem 0.6rem;
    margin-bottom: 0.35rem;
  }

  .hero-text h1 {
    font-size: 1.75rem;
    margin: 0;
  }

  .supporting-text {
    color: var(--muted);
    margin: 0;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
  }

  .location {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .location svg {
    display: block;
    flex-shrink: 0;
  }

  .bio {
    font-size: 0.875rem;
    color: var(--fg-soft);
    margin: 0 0 1.4rem;
  }

  .links {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg);
    font-size: 0.875rem;
    text-decoration: none;
    transition:
      color 0.15s,
      border-color 0.15s,
      background 0.15s;
  }

  .links a:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--card);
    text-decoration: none;
  }

  .links svg {
    display: block;
  }

  .page-links {
    display: flex;
    flex-direction: column;
  }

  .page-links a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 0;
    color: var(--fg);
    text-decoration: none;
    border-top: 1px solid var(--border);
    transition: color 0.15s;
  }

  .page-links a:last-child {
    border-bottom: 1px solid var(--border);
  }

  .page-links a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .page-links .label {
    font-size: 1rem;
    font-weight: 500;
  }

  .page-links .arrow {
    color: var(--muted);
    font-size: 1rem;
    transition:
      transform 0.15s,
      color 0.15s;
  }

  .page-links a:hover .arrow {
    color: var(--accent);
    transform: translateX(2px);
  }

  @media (max-width: 540px) {
    .hero {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .avatar {
      width: 72px;
      height: 72px;
    }
  }
</style>
