---
import Layout from "../layouts/Layout.astro";
---

<Layout prefix="404 Not Found">
  <section class="not-found">
    <p class="code">404</p>
    <h1>Not Found</h1>
    <p class="message">お探しのページは見つかりませんでした。</p>
    <a class="home-link" href="/">Home</a>
  </section>
</Layout>

<style>
  .not-found {
    text-align: center;
    padding: 3rem 0;
  }

  .code {
    color: var(--muted);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
  }

  .not-found h1 {
    font-size: 1.75rem;
    margin: 0 0 1rem;
  }

  .message {
    color: var(--fg-soft);
    font-size: 0.9rem;
    margin: 0 0 2rem;
  }

  .home-link {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg);
    font-size: 0.9rem;
    transition:
      color 0.15s,
      border-color 0.15s,
      background 0.15s;
  }

  .home-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--card);
    text-decoration: none;
  }
</style>
